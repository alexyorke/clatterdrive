<Window x:Class="ClatterDrive.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClatterDrive"
        Width="780"
        Height="620"
        MinWidth="680"
        MinHeight="520"
        Closing="Window_Closing">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="MinWidth" Value="72" />
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="26" />
    </Style>
  </Window.Resources>
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,14">
      <TextBlock Text="ClatterDrive" FontSize="28" FontWeight="SemiBold" />
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="160" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0" Text="Backing folder" FontWeight="SemiBold" />
      <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,10">
        <Button DockPanel.Dock="Right"
                Content="Browse"
                Click="BrowseButton_Click"
                AutomationProperties.AutomationId="BrowseBackingFolderButton" />
        <TextBox Text="{Binding BackingDirectory, UpdateSourceTrigger=PropertyChanged}"
                 AutomationProperties.AutomationId="BackingDirectoryTextBox" />
      </DockPanel>

      <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,10">
        <StackPanel Width="130" Margin="0,0,12,0">
          <TextBlock Text="Host" FontWeight="SemiBold" />
          <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.AutomationId="HostTextBox" />
        </StackPanel>
        <StackPanel Width="100" Margin="0,0,12,0">
          <TextBlock Text="Port" FontWeight="SemiBold" />
          <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.AutomationId="PortTextBox" />
        </StackPanel>
        <StackPanel Width="210" Margin="0,0,12,0">
          <TextBlock Text="Drive" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding DriveProfiles}"
                    SelectedItem="{Binding DriveProfile}"
                    AutomationProperties.AutomationId="DriveProfileComboBox" />
        </StackPanel>
        <StackPanel Width="190">
          <TextBlock Text="Mounting" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AcousticProfiles}"
                    SelectedItem="{Binding AcousticProfile}"
                    AutomationProperties.AutomationId="AcousticProfileComboBox" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,10">
        <StackPanel Width="130" Margin="0,0,12,0">
          <TextBlock Text="Audio" FontWeight="SemiBold" />
          <ComboBox ItemsSource="{Binding AudioModes}"
                    SelectedItem="{Binding AudioMode}"
                    AutomationProperties.AutomationId="AudioModeComboBox" />
        </StackPanel>
        <StackPanel Width="260">
          <TextBlock Text="Audio device (optional)" FontWeight="SemiBold" />
          <TextBox Text="{Binding AudioDevice, UpdateSourceTrigger=PropertyChanged}"
                   AutomationProperties.AutomationId="AudioDeviceTextBox" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
        <Button Content="Start"
                Command="{Binding StartCommand}"
                AutomationProperties.AutomationId="StartServerButton" />
        <Button Content="Stop"
                Command="{Binding StopCommand}"
                AutomationProperties.AutomationId="StopServerButton" />
        <Button Content="Open Browser"
                Click="OpenBrowserButton_Click"
                AutomationProperties.AutomationId="OpenBrowserButton" />
        <Button Content="Copy URL"
                Click="CopyUrlButton_Click"
                AutomationProperties.AutomationId="CopyUrlButton" />
        <Button Content="Copy Mount Command"
                Click="CopyMountButton_Click"
                AutomationProperties.AutomationId="CopyMountCommandButton" />
        <Button Content="Copy Unmount"
                Click="CopyUnmountButton_Click"
                AutomationProperties.AutomationId="CopyUnmountCommandButton" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2" Margin="0,16,0,12">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <DockPanel Grid.Row="0" Margin="0,0,0,6">
        <TextBlock Text="{Binding Status, StringFormat=Status: {0}}"
                   FontWeight="SemiBold"
                   AutomationProperties.AutomationId="StatusTextBlock" />
        <TextBlock Text="{Binding WebDavUrl}"
                   HorizontalAlignment="Right"
                   Foreground="#606060"
                   AutomationProperties.AutomationId="WebDavUrlTextBlock" />
      </DockPanel>
      <ListBox Grid.Row="1"
               ItemsSource="{Binding Logs}"
               FontFamily="Consolas"
               FontSize="12"
               AutomationProperties.AutomationId="LogListBox" />
    </Grid>
  </Grid>
</Window>
